# .env — Local development only. Never commit this file.
# On Render, these are set as Environment Variables in the dashboard
# or via the envVars block in render.yaml.
#
# Heroku equivalent: `heroku config:set KEY=value`

DATABASE_URL=postgres://localhost/job_tracker
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
RACK_ENV=development
PORT=4567
